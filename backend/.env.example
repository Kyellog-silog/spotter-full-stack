# Production settings (Render). All optional in local dev.
SECRET_KEY=generate-a-long-random-string
DEBUG=false
ALLOWED_HOSTS=.onrender.com
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# Optional: use OpenRouteService truck routing instead of OSRM
# ORS_API_KEY=
# Set to false only if the platform health check fails behind the HTTPS redirect
# SECURE_SSL_REDIRECT=true
